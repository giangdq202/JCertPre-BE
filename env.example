# Database Configuration
JCERTPRE_DB_CONNECTION_STRING="Server=YOUR_SERVER;User ID=YOUR_USERNAME;Password=YOUR_PASSWORD;Database=JCertPreDB;Trusted_Connection=False;TrustServerCertificate=True"

# JWT Configuration (minimum 32 characters each)
JWT_SECRET_KEY="your-super-secret-jwt-key-at-least-32-characters-long-for-security"
JWT_REFRESH_SECRET_KEY="your-refresh-secret-key-also-at-least-32-characters-long"
JWT_ISSUER="JCertPre-API"
JWT_AUDIENCE="JCertPre-Client"
JWT_EXPIRY_MINUTES="60"

# API Configuration
ASPNETCORE_ENVIRONMENT="Development"
ASPNETCORE_URLS="https://localhost:7001;http://localhost:5001"

# CORS Configuration
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://localhost:3000,http://localhost:5173,https://localhost:5173"

# Logging Configuration
LOG_LEVEL="Information"
LOG_ENABLE_SQL_LOGGING="true"

# Security Configuration
ENABLE_HTTPS_REDIRECTION="true"
TRUST_SERVER_CERTIFICATE="true"

# Application Configuration
APP_NAME="JCertPre"
APP_VERSION="1.0.0"
DEFAULT_PAGE_SIZE="10"
MAX_FILE_SIZE_MB="10"

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email Configuration (for notifications)
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="587"
EMAIL_USERNAME=""
EMAIL_PASSWORD=""
EMAIL_FROM_ADDRESS="noreply@jcertpre.com"
EMAIL_FROM_NAME="JCertPre System"

# Redis Configuration (for caching - optional)
REDIS_CONNECTION_STRING=""
REDIS_INSTANCE_NAME="JCertPre"

# File Storage Configuration
FILE_STORAGE_PATH="uploads"
ALLOWED_FILE_EXTENSIONS=".pdf,.doc,.docx,.jpg,.jpeg,.png,.gif"
TEMP_FILE_CLEANUP_HOURS="24"

# External API Configuration (if needed)
EXTERNAL_API_BASE_URL=""
EXTERNAL_API_KEY=""
EXTERNAL_API_TIMEOUT_SECONDS="30" 